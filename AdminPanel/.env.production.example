# Copy to .env.production and replace values.

NODE_ENV=production
PORT=3000

# Backend service URL (Render)
NEXT_PUBLIC_API_BASE_URL=https://adminbackend-qzb4.onrender.com

# Storefront URL for "View" button
NEXT_PUBLIC_STOREFRONT_URL=https://quirky-home.vercel.app

# Shared PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Optional AWS/Dynamo settings (if used by your admin features)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<your_access_key>
AWS_SECRET_ACCESS_KEY=<your_secret_key>
AWS_SESSION_TOKEN=
DYNAMODB_TABLE_NAME=erpdev
