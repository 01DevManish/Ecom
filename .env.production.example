# Copy to .env.production and replace values.

NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_BASE_URL=https://qhbackend.onrender.com
NEXT_PUBLIC_API_URL=https://qhbackend.onrender.com/api

# Local PostgreSQL on EC2 instance
DATABASE_URL=postgresql://quirkyhome_user:change-me-strong-password@127.0.0.1:5432/quirkyhome?sslmode=disable

# DynamoDB inventory import is read-only in admin.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace-with-read-only-key
AWS_SECRET_ACCESS_KEY=replace-with-read-only-secret
AWS_SESSION_TOKEN=
DYNAMODB_TABLE_NAME=replace-with-inventory-table-name
